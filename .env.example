# Alpaca (paper only — live keys will cause an immediate hard error at startup)
ALPACA_API_KEY=your_paper_api_key
ALPACA_SECRET_KEY=your_paper_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Finnhub
FINNHUB_API_KEY=your_finnhub_api_key

# Email notifications (optional — set EMAIL_ENABLED=false to disable)
EMAIL_ENABLED=false
EMAIL_RECIPIENT=you@example.com
EMAIL_SENDER=yourbot@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password

# Optional path overrides (defaults are shown)
# DB_PATH=tradingbot.db
# REPORTS_DIR=reports
# WATCHLIST_PATH=config/watchlist.yaml
